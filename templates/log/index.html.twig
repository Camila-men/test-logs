{% extends 'base.html.twig' %}

{% block title %}Логи авторизации{% endblock %}

{% block body %}
    <h1 class="h3 mb-4">Логи авторизации и регистрации</h1>

    <form method="get" class="row g-2 mb-4 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Действие</label>
            <select name="action" class="form-select">
                <option value="">Все</option>
                {% for a in actions %}
                    <option value="{{ a }}" {{ filters.action == a ? 'selected' }}>{{ a }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Статус</label>
            <select name="status" class="form-select">
                <option value="">Все</option>
                {% for s in statuses %}
                    <option value="{{ s }}" {{ filters.status == s ? 'selected' }}>{{ s }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-1">
            <label class="form-label">User ID</label>
            <input type="number" name="userId" class="form-control" value="{{ filters.userId }}">
        </div>
        <div class="col-md-2">
            <label class="form-label">IP</label>
            <input type="text" name="ip" class="form-control" value="{{ filters.ip }}">
        </div>
        <div class="col-md-2">
            <label class="form-label">User-Agent</label>
            <input type="text" name="userAgent" class="form-control" value="{{ filters.userAgent }}">
        </div>
        <div class="col-md-1">
            <label class="form-label">С даты</label>
            <input type="date" name="dateFrom" class="form-control" value="{{ filters.dateFrom }}">
        </div>
        <div class="col-md-1">
            <label class="form-label">По дату</label>
            <input type="date" name="dateTo" class="form-control" value="{{ filters.dateTo }}">
        </div>
        <div class="col-md-1 d-grid">
            <button type="submit" class="btn btn-primary">Найти</button>
        </div>
    </form>

    <p class="text-muted">Всего записей: {{ total }}</p>

    <div class="table-responsive">
        <table class="table table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Действие</th>
                    <th>Статус</th>
                    <th>User ID</th>
                    <th>IP</th>
                    <th>User-Agent</th>
                    <th>Ошибка</th>
                    <th>Время</th>
                </tr>
            </thead>
            <tbody>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.id }}</td>
                        <td>{{ log.action }}</td>
                        <td>
                            <span class="badge {{ log.status == 'success' ? 'bg-success' : 'bg-danger' }}">{{ log.status }}</span>
                        </td>
                        <td>{{ log.user ? log.user.id : '—' }}</td>
                        <td>{{ log.ip }}</td>
                        <td class="text-truncate" style="max-width: 240px;" title="{{ log.userAgent }}">{{ log.userAgent }}</td>
                        <td class="text-truncate" style="max-width: 240px;" title="{{ log.errorMessage }}">{{ log.errorMessage }}</td>
                        <td>{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-muted">Записей не найдено</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
        <nav>
            <ul class="pagination">
                {% for p in 1..pages %}
                    <li class="page-item {{ p == page ? 'active' }}">
                        <a class="page-link" href="{{ path('app_log_index', filters|filter(v => v != '')|merge({page: p})) }}">{{ p }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}
{% endblock %}
